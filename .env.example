# SnipSnap Environment Variables
# Copy this file to .env and fill in your values.

# Required for curation (LLM analysis via OpenRouter)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Optional overrides (uncomment and set to customize)

# Directory where transcriptions and cut lists are stored
# Default: ./snipsnap_data/
# SNIPSNAP_DATA_DIR=./snipsnap_data/

# LLM model used for curation (via OpenRouter)
# Default: google/gemini-2.5-flash-lite
# SNIPSNAP_MODEL=google/gemini-2.5-flash-lite

# Whisper model size for local transcription
# Options: tiny, base, small, medium, large-v2, large-v3
# Default: small
# SNIPSNAP_WHISPER_MODEL=small
